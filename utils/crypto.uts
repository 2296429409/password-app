/**
 * 加密模块：PBKDF2-SHA256 派生密钥 + AES-256-CBC
 * 纯 UTS 实现，无第三方依赖，Web / Android 通用
 */

type KdfParams = {
  algorithm : string
  salt : string
  iterations : number
}

const PBKDF2_ITERATIONS = 100000
const KEY_SIZE = 32
const IV_SIZE = 16

const B64_CHARS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/'

export function base64Encode(bytes : number[]) : string {
  let result = ''
  const len = bytes.length
  let i = 0
  while (i < len) {
    const b0 = bytes[i]
    const b1 = i + 1 < len ? bytes[i + 1] : 0
    const b2 = i + 2 < len ? bytes[i + 2] : 0
    result += B64_CHARS.charAt(b0 >> 2)
    result += B64_CHARS.charAt(((b0 & 3) << 4) | (b1 >> 4))
    result += i + 1 < len ? B64_CHARS.charAt(((b1 & 15) << 2) | (b2 >> 6)) : '='
    result += i + 2 < len ? B64_CHARS.charAt(b2 & 63) : '='
    i += 3
  }
  return result
}

export function base64Decode(str : string) : number[] {
  const lookup = new Map<string, number>()
  for (let i = 0; i < 64; i++) {
    lookup.set(B64_CHARS.charAt(i), i)
  }
  const bytes : number[] = []
  const cleaned = str.replace(/\s/g, '')
  let i = 0
  while (i < cleaned.length) {
    const c0 = lookup.get(cleaned.charAt(i)) ?? 0
    const c1 = i + 1 < cleaned.length ? (lookup.get(cleaned.charAt(i + 1)) ?? 0) : 0
    const c2 = i + 2 < cleaned.length ? (lookup.get(cleaned.charAt(i + 2)) ?? 0) : 0
    const c3 = i + 3 < cleaned.length ? (lookup.get(cleaned.charAt(i + 3)) ?? 0) : 0
    bytes.push((c0 << 2) | (c1 >> 4))
    if (cleaned.charAt(i + 2) != '=') {
      bytes.push(((c1 & 15) << 4) | (c2 >> 2))
    }
    if (cleaned.charAt(i + 3) != '=') {
      bytes.push(((c2 & 3) << 6) | c3)
    }
    i += 4
  }
  return bytes
}

export function stringToBytes(str : string) : number[] {
  const bytes : number[] = []
  for (let i = 0; i < str.length; i++) {
    const code = str.charCodeAt(i)
    if (code < 0x80) {
      bytes.push(code)
    } else if (code < 0x800) {
      bytes.push(0xc0 | (code >> 6), 0x80 | (code & 0x3f))
    } else {
      bytes.push(0xe0 | (code >> 12), 0x80 | ((code >> 6) & 0x3f), 0x80 | (code & 0x3f))
    }
  }
  return bytes
}

export function bytesToString(bytes : number[]) : string {
  let result = ''
  let i = 0
  while (i < bytes.length) {
    const b0 = bytes[i]
    if (b0 < 0x80) {
      result += String.fromCharCode(b0)
      i++
    } else if (b0 < 0xe0) {
      result += String.fromCharCode(((b0 & 0x1f) << 6) | (bytes[i + 1] & 0x3f))
      i += 2
    } else {
      result += String.fromCharCode(((b0 & 0x0f) << 12) | ((bytes[i + 1] & 0x3f) << 6) | (bytes[i + 2] & 0x3f))
      i += 3
    }
  }
  return result
}

function rotr(n : number, x : number) : number {
  return (x >>> n) | (x << (32 - n))
}

function sha256Block(h : number[], chunk : number[]) : void {
  const k = [
    0x428a2f98, 0x71374491, 0xb5c0fbcf, 0xe9b5dba5, 0x3956c25b, 0x59f111f1, 0x923f82a4, 0xab1c5ed5,
    0xd807aa98, 0x12835b01, 0x243185be, 0x550c7dc3, 0x72be5d74, 0x80deb1fe, 0x9bdc06a7, 0xc19bf174,
    0xe49b69c1, 0xefbe4786, 0x0fc19dc6, 0x240ca1cc, 0x2de92c6f, 0x4a7484aa, 0x5cb0a9dc, 0x76f988da,
    0x983e5152, 0xa831c66d, 0xb00327c8, 0xbf597fc7, 0xc6e00bf3, 0xd5a79147, 0x06ca6351, 0x14292967,
    0x27b70a85, 0x2e1b2138, 0x4d2c6dfc, 0x53380d13, 0x650a7354, 0x766a0abb, 0x81c2c92e, 0x92722c85,
    0xa2bfe8a1, 0xa81a664b, 0xc24b8b70, 0xc76c51a3, 0xd192e819, 0xd6990624, 0xf40e3585, 0x106aa070,
    0x19a4c116, 0x1e376c08, 0x2748774c, 0x34b0bcb5, 0x391c0cb3, 0x4ed8aa4a, 0x5b9cca4f, 0x682e6ff3,
    0x748f82ee, 0x78a5636f, 0x84c87814, 0x8cc70208, 0x90befffa, 0xa4506ceb, 0xbef9a3f7, 0xc67178f2
  ]
  const w : number[] = []
  for (let i = 0; i < 16; i++) {
    w.push((chunk[i * 4] << 24) | (chunk[i * 4 + 1] << 16) | (chunk[i * 4 + 2] << 8) | chunk[i * 4 + 3])
  }
  for (let i = 16; i < 64; i++) {
    const s0 = rotr(7, w[i - 15]) ^ rotr(18, w[i - 15]) ^ (w[i - 15] >>> 3)
    const s1 = rotr(17, w[i - 2]) ^ rotr(19, w[i - 2]) ^ (w[i - 2] >>> 10)
    w.push((w[i - 16] + s0 + w[i - 7] + s1) | 0)
  }
  let a = h[0], b = h[1], c = h[2], d = h[3], e = h[4], f = h[5], g = h[6], hh = h[7]
  for (let i = 0; i < 64; i++) {
    const S1 = rotr(6, e) ^ rotr(11, e) ^ rotr(25, e)
    const ch = (e & f) ^ (~e & g)
    const t1 = (hh + S1 + ch + k[i] + w[i]) | 0
    const S0 = rotr(2, a) ^ rotr(13, a) ^ rotr(22, a)
    const maj = (a & b) ^ (a & c) ^ (b & c)
    const t2 = (S0 + maj) | 0
    hh = g; g = f; f = e; e = (d + t1) | 0
    d = c; c = b; b = a; a = (t1 + t2) | 0
  }
  h[0] = (h[0] + a) | 0; h[1] = (h[1] + b) | 0; h[2] = (h[2] + c) | 0; h[3] = (h[3] + d) | 0
  h[4] = (h[4] + e) | 0; h[5] = (h[5] + f) | 0; h[6] = (h[6] + g) | 0; h[7] = (h[7] + hh) | 0
}

export function sha256(data : number[]) : number[] {
  const h = [0x6a09e667, 0xbb67ae85, 0x3c6ef372, 0xa54ff53a, 0x510e527f, 0x9b05688c, 0x1f83d9ab, 0x5be0cd19]
  const bitLen = data.length * 8
  const padded : number[] = []
  for (let i = 0; i < data.length; i++) padded.push(data[i])
  padded.push(0x80)
  while ((padded.length % 64) != 56) padded.push(0)
  padded.push(0, 0, 0, 0)
  padded.push((bitLen >>> 24) & 0xff, (bitLen >>> 16) & 0xff, (bitLen >>> 8) & 0xff, bitLen & 0xff)
  for (let i = 0; i < padded.length; i += 64) {
    sha256Block(h, padded.slice(i, i + 64))
  }
  const result : number[] = []
  for (let i = 0; i < 8; i++) {
    result.push((h[i] >>> 24) & 0xff, (h[i] >>> 16) & 0xff, (h[i] >>> 8) & 0xff, h[i] & 0xff)
  }
  return result
}

export function hmacSha256(key : number[], data : number[]) : number[] {
  const blockSize = 64
  let k = key
  if (k.length > blockSize) k = sha256(k)
  while (k.length < blockSize) k.push(0)
  const ipad : number[] = []
  const opad : number[] = []
  for (let i = 0; i < blockSize; i++) {
    ipad.push(k[i] ^ 0x36)
    opad.push(k[i] ^ 0x5c)
  }
  const inner = sha256(ipad.concat(data))
  return sha256(opad.concat(inner))
}

export function pbkdf2(password : string, salt : string, iterations : number, keyLen : number) : number[] {
  const pwBytes = stringToBytes(password)
  const saltBytes = stringToBytes(salt)
  const result : number[] = []
  let blockIndex = 1
  while (result.length < keyLen) {
    const blockNum = stringToBytes(blockIndex.toString())
    let u = hmacSha256(pwBytes, saltBytes.concat(blockNum))
    const block = u.slice(0)
    for (let i = 1; i < iterations; i++) {
      u = hmacSha256(pwBytes, u)
      for (let j = 0; j < block.length; j++) block[j] = (block[j] ^ u[j]) | 0
    }
    for (let j = 0; j < block.length && result.length < keyLen; j++) result.push(block[j])
    blockIndex++
  }
  return result.slice(0, keyLen)
}

