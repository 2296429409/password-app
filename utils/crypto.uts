  0x3a,0x91,0x11,0x41,0x4f,0x67,0xdc,0xea,0x97,0xf2,0xcf,0xce,0xf0,0xb4,0xe6,0x73,
  0x96,0xac,0x74,0x22,0xe7,0xad,0x35,0x85,0xe2,0xf9,0x37,0xe8,0x1c,0x75,0xdf,0x6e,
  0x47,0xf1,0x1a,0x71,0x1d,0x29,0xc5,0x89,0x6f,0xb7,0x62,0x0e,0xaa,0x18,0xbe,0x1b,
  0xfc,0x56,0x3e,0x4b,0xc6,0xd2,0x79,0x20,0x9a,0xdb,0xc0,0xfe,0x78,0xcd,0x5a,0xf4,
  0x1f,0xdd,0xa8,0x33,0x88,0x07,0xc7,0x31,0xb1,0x12,0x10,0x59,0x27,0x80,0xec,0x5f,
  0x60,0x51,0x7f,0xa9,0x19,0xb5,0x4a,0x0d,0x2d,0xe5,0x7a,0x9f,0x93,0xc9,0x9c,0xef,
  0xa0,0xe0,0x3b,0x4d,0xae,0x2a,0xf5,0xb0,0xc8,0xeb,0xbb,0x3c,0x83,0x53,0x99,0x61,
  0x17,0x2b,0x04,0x7e,0xba,0x77,0xd6,0x26,0xe1,0x69,0x14,0x63,0x55,0x21,0x0c,0x7d
]

const RCON = [0x01,0x02,0x04,0x08,0x10,0x20,0x40,0x80,0x1b,0x36]

function keyExpansion(key : number[]) : number[] {
  const w : number[] = key.slice(0)
  let i = 8
  while (i < 60) {
    let t = w.slice((i - 1) * 4, i * 4)
    if (i % 8 == 0) {
      t = [SBOX[t[1]] ^ RCON[(i / 8) - 1], SBOX[t[2]], SBOX[t[3]], SBOX[t[0]]]
    } else if (i % 8 == 4) {
      t = [SBOX[t[0]], SBOX[t[1]], SBOX[t[2]], SBOX[t[3]]]
    }
    for (let j = 0; j < 4; j++) w.push((w[(i - 8) * 4 + j] ^ t[j]) & 0xff)
    i++
  }
  return w
}

function addRoundKey(state : number[], roundKey : number[], round : number) : void {
  for (let i = 0; i < 16; i++) state[i] ^= roundKey[round * 16 + i]
}

function subBytes(state : number[], inv : boolean) : void {
  const box = inv ? RSBOX : SBOX
  for (let i = 0; i < 16; i++) state[i] = box[state[i]]
}

function shiftRows(state : number[], inv : boolean) : void {
  for (let row = 1; row < 4; row++) {
    const temp : number[] = []
    for (let col = 0; col < 4; col++) temp.push(state[row + col * 4])
    for (let col = 0; col < 4; col++) {
      if (inv) {
        state[row + col * 4] = temp[(col + 4 - row) % 4]
      } else {
        state[row + col * 4] = temp[(col + row) % 4]
      }
    }
  }
}

function xtime(x : number) : number { return ((x << 1) ^ (((x >> 7) & 1) * 0x1b)) & 0xff }

function gmul(a : number, b : number) : number {
  let p = 0
  let aa = a
  let bb = b
  for (let i = 0; i < 8; i++) {
    if ((bb & 1) != 0) p = (p ^ aa) & 0xff
    const hi = aa & 0x80
    aa = (aa << 1) & 0xff
    if (hi != 0) aa = (aa ^ 0x1b) & 0xff
    bb = bb >> 1
  }
  return p
}

function mixColumns(state : number[], inv : boolean) : void {
  for (let col = 0; col < 4; col++) {
    const i = col * 4
    const a0 = state[i], a1 = state[i + 1], a2 = state[i + 2], a3 = state[i + 3]
    if (inv) {
      state[i]     = (gmul(a0, 0x0e) ^ gmul(a1, 0x0b) ^ gmul(a2, 0x0d) ^ gmul(a3, 0x09)) & 0xff
      state[i + 1] = (gmul(a0, 0x09) ^ gmul(a1, 0x0e) ^ gmul(a2, 0x0b) ^ gmul(a3, 0x0d)) & 0xff
      state[i + 2] = (gmul(a0, 0x0d) ^ gmul(a1, 0x09) ^ gmul(a2, 0x0e) ^ gmul(a3, 0x0b)) & 0xff
      state[i + 3] = (gmul(a0, 0x0b) ^ gmul(a1, 0x0d) ^ gmul(a2, 0x09) ^ gmul(a3, 0x0e)) & 0xff
    } else {
      state[i]     = (gmul(a0, 2) ^ gmul(a1, 3) ^ a2 ^ a3) & 0xff
      state[i + 1] = (a0 ^ gmul(a1, 2) ^ gmul(a2, 3) ^ a3) & 0xff
      state[i + 2] = (a0 ^ a1 ^ gmul(a2, 2) ^ gmul(a3, 3)) & 0xff
      state[i + 3] = (gmul(a0, 3) ^ a1 ^ a2 ^ gmul(a3, 2)) & 0xff
    }
  }
}

function aesBlock(block : number[], expandedKey : number[], encrypt : boolean) : number[] {
  const state = block.slice(0)
  const rounds = 14
  if (encrypt) {
    addRoundKey(state, expandedKey, 0)
    for (let r = 1; r < rounds; r++) {
      subBytes(state, false); shiftRows(state, false); mixColumns(state, false); addRoundKey(state, expandedKey, r)
    }
    subBytes(state, false); shiftRows(state, false); addRoundKey(state, expandedKey, rounds)
  } else {
    addRoundKey(state, expandedKey, rounds)
    for (let r = rounds - 1; r > 0; r--) {
      shiftRows(state, true); subBytes(state, true); addRoundKey(state, expandedKey, r); mixColumns(state, true)
    }
    shiftRows(state, true); subBytes(state, true); addRoundKey(state, expandedKey, 0)
  }
  return state
}

function pkcs7Pad(data : number[], blockSize : number) : number[] {
  const pad = blockSize - (data.length % blockSize)
  const result = data.slice(0)
  for (let i = 0; i < pad; i++) result.push(pad)
  return result
}

function pkcs7Unpad(data : number[]) : number[] | null {
  if (data.length == 0) return null
  const pad = data[data.length - 1]
  if (pad < 1 || pad > 16 || pad > data.length) return null
  for (let i = 0; i < pad; i++) {
    if (data[data.length - 1 - i] != pad) return null
  }
  return data.slice(0, data.length - pad)
}

export function aesEncrypt(plaintext : string, key : number[], iv : number[]) : string {
  const expandedKey = keyExpansion(key)
  const data = pkcs7Pad(stringToBytes(plaintext), 16)
  const result : number[] = []
  let prev = iv.slice(0)
  for (let i = 0; i < data.length; i += 16) {
    const block = data.slice(i, i + 16)
    for (let j = 0; j < 16; j++) block[j] ^= prev[j]
    const encrypted = aesBlock(block, expandedKey, true)
    for (let j = 0; j < 16; j++) result.push(encrypted[j])
    prev = encrypted
  }
  return base64Encode(result)
}

export function aesDecrypt(ciphertext : string, key : number[], iv : number[]) : string {
  const expandedKey = keyExpansion(key)
  const data = base64Decode(ciphertext)
  const result : number[] = []
  let prev = iv.slice(0)
  for (let i = 0; i < data.length; i += 16) {
    const block = data.slice(i, i + 16)
    const decrypted = aesBlock(block, expandedKey, false)
    for (let j = 0; j < 16; j++) result.push(decrypted[j] ^ prev[j])
    prev = block
  }
  const unpadded = pkcs7Unpad(result)
  if (unpadded == null) return ''
  return bytesToString(unpadded)
}

export function generateSalt() : string {
  const bytes : number[] = []
  for (let i = 0; i < 16; i++) bytes.push(Math.floor(Math.random() * 256))
  return base64Encode(bytes)
}

export function generateIV() : string {
  const bytes : number[] = []
  for (let i = 0; i < IV_SIZE; i++) bytes.push(Math.floor(Math.random() * 256))
  return base64Encode(bytes)
}

export function createKdfParams(salt : string) : KdfParams {
  return { algorithm: 'pbkdf2-sha256', salt: salt, iterations: PBKDF2_ITERATIONS }
}

export function deriveKey(password : string, kdf : KdfParams) : number[] {
  return pbkdf2(password, kdf.salt, kdf.iterations, KEY_SIZE)
}

export function encryptData(plaintext : string, password : string, kdf : KdfParams, ivStr : string) : string {
  const key = deriveKey(password, kdf)
  const iv = base64Decode(ivStr)
  return aesEncrypt(plaintext, key, iv)
}

export function decryptData(ciphertext : string, password : string, kdf : KdfParams, ivStr : string) : string {
  const key = deriveKey(password, kdf)
  const iv = base64Decode(ivStr)
  return aesDecrypt(ciphertext, key, iv)
}

/** 使用密钥文件中的主密钥加密（无密码） */
export function encryptWithKey(plaintext : string, key : number[], ivStr : string) : string {
  const iv = base64Decode(ivStr)
  return aesEncrypt(plaintext, key, iv)
}

/** 使用密钥文件中的主密钥解密 */
export function decryptWithKey(ciphertext : string, key : number[], ivStr : string) : string {
  const iv = base64Decode(ivStr)
  return aesDecrypt(ciphertext, key, iv)
}

export function generateId() : string {
  const chars = 'abcdefghijklmnopqrstuvwxyz0123456789'
  let id = ''
  for (let i = 0; i < 16; i++) id += chars.charAt(Math.floor(Math.random() * chars.length))
  return id + Date.now().toString(36)
}
